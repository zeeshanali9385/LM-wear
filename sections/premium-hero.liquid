<section
  class="premium-section premium-hero"
  id="PremiumHero-{{ section.id }}"
  style="
    --premium-hero-min-height: {{ section.settings.min_height }}vh;
    --premium-hero-overlay: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    --premium-hero-text: {{ section.settings.text_color }};
    --premium-hero-overlay-color: {{ section.settings.overlay_color }};
    --premium-hero-content-max: {{ section.settings.content_max_width }}px;
    --premium-btn-bg: {{ section.settings.button_background }};
    --premium-btn-text: {{ section.settings.button_text_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  "
  aria-label="{{ section.settings.heading | escape }}"
>
  <div class="premium-hero__media" aria-hidden="true">
    {% if section.settings.image != blank %}
      {{
        section.settings.image
        | image_url: width: 2400
        | image_tag:
          loading: 'eager',
          fetchpriority: 'high',
          widths: '750, 1100, 1500, 2000, 2400',
          sizes: '100vw',
          alt: section.settings.image_alt | escape
      }}
    {% else %}
      {{ 'lifestyle-2' | placeholder_svg_tag: 'premium-hero__placeholder' }}
    {% endif %}
    <div class="premium-hero__overlay"></div>
  </div>

  <div class="premium-hero__content">
    <div class="page-width">
      <div class="premium-hero__text premium-hero__text--{{ section.settings.text_alignment }}">
        {% if section.settings.eyebrow != blank %}
          <span class="premium-section__eyebrow beauty-reveal">{{ section.settings.eyebrow }}</span>
        {% endif %}
        {% if section.settings.heading != blank %}
          <h1 class="premium-section__heading beauty-reveal beauty-reveal--delay-1">{{ section.settings.heading }}</h1>
        {% endif %}
        {% if section.settings.subheading != blank %}
          <p class="premium-section__subheading beauty-reveal beauty-reveal--delay-2">{{ section.settings.subheading }}</p>
        {% endif %}
        {% if section.settings.button_label != blank %}
          <div class="premium-hero__actions beauty-reveal beauty-reveal--delay-3">
            <a
              href="{{ section.settings.button_link }}"
              class="premium-btn premium-btn--{{ section.settings.button_style }}"
            >
              {{ section.settings.button_label }}
            </a>
          </div>
        {% endif %}
      </div>
    </div>
  </div>
</section>

{% stylesheet %}
  .premium-hero {
    position: relative;
    display: flex;
    align-items: flex-end;
    min-height: var(--premium-hero-min-height, 85vh);
    overflow: hidden;
    color: var(--premium-hero-text, #fff);
    width: 100%;
    background: #1c1917;
  }

  .premium-hero__media {
    position: absolute;
    inset: 0;
  }

  .premium-hero__media img,
  .premium-hero__placeholder {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transform: scale(1.02);
    animation: premium-hero- ken 18s ease-out forwards;
  }

  .premium-hero__overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(
        180deg,
        color-mix(in srgb, var(--premium-hero-overlay-color, #1c1917) 8%, transparent) 0%,
        color-mix(in srgb, var(--premium-hero-overlay-color, #1c1917) 55%, transparent) 100%
      ),
      var(--premium-hero-overlay-color, #1c1917);
    opacity: var(--premium-hero-overlay, 0.4);
  }

  .premium-hero__content {
    position: relative;
    z-index: 1;
    width: 100%;
    display: flex;
    align-items: flex-end;
    min-height: inherit;
    padding-block: 3.5rem 4.5rem;
  }

  .premium-hero__text {
    max-width: var(--premium-hero-content-max, 560px);
  }

  .premium-hero__text .premium-section__eyebrow {
    color: color-mix(in srgb, var(--premium-hero-text, #fff) 82%, transparent);
  }

  .premium-hero__text .premium-section__heading {
    margin-bottom: 1rem;
  }

  .premium-hero__text .premium-section__subheading {
    color: color-mix(in srgb, var(--premium-hero-text, #fff) 88%, transparent);
    max-width: 32rem;
    margin-bottom: 1.75rem;
  }

  .premium-hero__text--left {
    margin-inline: 0 auto;
    text-align: left;
  }

  .premium-hero__text--center {
    margin-inline: auto;
    text-align: center;
  }

  .premium-hero__text--center .premium-section__subheading {
    margin-inline: auto;
  }

  .premium-hero__actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem;
  }

  @keyframes premium-hero-ken {
    from {
      transform: scale(1.06);
    }
    to {
      transform: scale(1);
    }
  }

  @media screen and (max-width: 749px) {
    .premium-hero {
      min-height: min(92svh, 720px);
      align-items: flex-end;
    }

    .premium-hero__content {
      padding-block: 2.5rem 3rem;
    }

    .premium-hero__actions .premium-btn {
      width: 100%;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .premium-hero__media img,
    .premium-hero__placeholder {
      animation: none;
      transform: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Premium Hero",
  "tag": "section",
  "class": "premium-hero-section",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Sensitive Skin · Healthy Glow"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "All-Day Hydration"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Hyaluronic + ceramides. Barrier-safe care for calm, radiant skin."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop Hydration"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "select",
      "id": "button_style",
      "label": "Button style",
      "options": [
        { "value": "primary", "label": "Primary" },
        { "value": "secondary", "label": "Secondary" }
      ],
      "default": "primary"
    },
    {
      "type": "header",
      "content": "Media"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background image"
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Image alt text",
      "info": "Describe the image for accessibility and SEO"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "label": "Overlay opacity",
      "default": 35
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" }
      ],
      "default": "left"
    },
    {
      "type": "range",
      "id": "content_max_width",
      "min": 400,
      "max": 800,
      "step": 20,
      "unit": "px",
      "label": "Content max width",
      "default": 560
    },
    {
      "type": "range",
      "id": "min_height",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "vh",
      "label": "Minimum height",
      "default": 90
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_background",
      "label": "Button background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text color",
      "default": "#1c1917"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Premium Hero"
    }
  ]
}
{% endschema %}
