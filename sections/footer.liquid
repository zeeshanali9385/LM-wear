

{% liquid
  if section.settings.background_color != blank
    render 'contrast-override', background_color: section.settings.background_color, section_id: section.id
  endif
%}

<section
  class="premium-footer{% if section.settings.background_color != blank %} color-custom-{{ section.id }}{% endif %}"
  style="
    background-color: {{ section.settings.background_color }};
    color: {{ section.settings.text_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="page-width premium-footer__inner">
    <div class="premium-footer__column premium-footer__column--brand">
      {% if section.settings.logo != blank %}
        {{
          section.settings.logo
          | image_url: width: 320
          | image_tag:
            loading: 'lazy',
            widths: '120, 180, 240, 320',
            sizes: '180px',
            class: 'premium-footer__logo',
            alt: section.settings.logo_alt | default: shop.name | escape
        }}
      {% else %}
        <h2 class="premium-footer__brand-name">{{ section.settings.brand_name | default: shop.name }}</h2>
      {% endif %}
      {% if section.settings.brand_description != blank %}
        <p class="premium-footer__brand-description">{{ section.settings.brand_description }}</p>
      {% endif %}
    </div>

    <div class="premium-footer__column">
      <h2 class="premium-footer__heading">{{ section.settings.quick_links_heading }}</h2>
      {% if section.settings.quick_links_menu != blank %}
        <ul class="premium-footer__links" role="list">
          {% for link in section.settings.quick_links_menu.links %}
            <li><a href="{{ link.url }}">{{ link.title }}</a></li>
          {% endfor %}
        </ul>
      {% endif %}
    </div>

    <div class="premium-footer__column">
      <h2 class="premium-footer__heading">{{ section.settings.support_links_heading }}</h2>
      {% if section.settings.support_links_menu != blank %}
        <ul class="premium-footer__links" role="list">
          {% for link in section.settings.support_links_menu.links %}
            <li><a href="{{ link.url }}">{{ link.title }}</a></li>
          {% endfor %}
        </ul>
      {% endif %}
    </div>
  </div>
</section>

{% stylesheet %}
  .premium-footer__inner {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
  }

  @media screen and (min-width: 750px) {
    .premium-footer__inner {
      grid-template-columns: 1.4fr 1fr 1fr;
      gap: 3rem;
    }
  }

  .premium-footer__heading,
  .premium-footer__brand-name {
    margin: 0 0 1rem;
    font-size: var(--premium-h3-size-mobile, 20px) !important;
    line-height: 1.25;
  }

  .premium-footer__brand-description {
    margin: 0;
    max-width: 34ch;
    opacity: 0.8;
    line-height: var(--premium-body-line-height, 1.6);
  }

  .premium-footer__logo {
    margin-bottom: 1rem;
    height: auto;
    width: auto;
    max-width: min(180px, 100%);
  }

  .premium-footer__links {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    gap: 0.75rem;
  }

  .premium-footer__links a {
    text-decoration: none;
    color: inherit;
    opacity: 0.85;
    transition: opacity 0.2s ease;
  }

  .premium-footer__links a:hover {
    opacity: 1;
  }

  @media screen and (min-width: 750px) {
    .premium-footer__heading,
    .premium-footer__brand-name {
      font-size: var(--premium-h3-size, 24px) !important;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Premium Footer",
  "enabled_on": {
    "groups": ["footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Brand info"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Brand logo"
    },
    {
      "type": "text",
      "id": "logo_alt",
      "label": "Logo alt text"
    },
    {
      "type": "text",
      "id": "brand_name",
      "label": "Brand name fallback",
      "default": "LM Wear"
    },
    {
      "type": "textarea",
      "id": "brand_description",
      "label": "Brand description",
      "default": "Premium essentials for beauty and innerwear, thoughtfully designed for modern comfort."
    },
    {
      "type": "header",
      "content": "Quick links column"
    },
    {
      "type": "text",
      "id": "quick_links_heading",
      "label": "Heading",
      "default": "Quick Links"
    },
    {
      "type": "link_list",
      "id": "quick_links_menu",
      "label": "Menu"
    },
    {
      "type": "header",
      "content": "Support / policies column"
    },
    {
      "type": "text",
      "id": "support_links_heading",
      "label": "Heading",
      "default": "Support & Policies"
    },
    {
      "type": "link_list",
      "id": "support_links_menu",
      "label": "Menu"
    },
    {
      "type": "header",
      "content": "Styles"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#111111"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 56
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 56
    }
  ],
  "presets": [
    {
      "name": "Premium Footer"
    }
  ]
}
{% endschema %}
