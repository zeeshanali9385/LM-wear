<section
  class="premium-section premium-trust-bar"
  id="PremiumTrustBar-{{ section.id }}"
  style="
    background-color: {{ section.settings.background_color }};
    color: {{ section.settings.text_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  "
  aria-label="{{ section.settings.heading | default: 'Trust badges' | escape }}"
>
  <div class="page-width">
    {% if section.settings.heading != blank %}
      <h2 class="visually-hidden">{{ section.settings.heading }}</h2>
    {% endif %}
    <ul class="premium-trust-bar__list" role="list">
      {% for block in section.blocks %}
        <li class="premium-trust-bar__item" {{ block.shopify_attributes }}>
          {% if block.settings.icon != blank %}
            <div class="premium-trust-bar__icon">
              {{
                block.settings.icon
                | image_url: width: 80
                | image_tag:
                  loading: 'lazy',
                  width: 40,
                  height: 40,
                  alt: block.settings.icon_alt | default: block.settings.title | escape
              }}
            </div>
          {% endif %}
          <div class="premium-trust-bar__text">
            {% if block.settings.title != blank %}
              <h3 class="premium-trust-bar__title">{{ block.settings.title }}</h3>
            {% endif %}
            {% if block.settings.description != blank %}
              <p class="premium-trust-bar__desc">{{ block.settings.description }}</p>
            {% endif %}
          </div>
        </li>
      {% else %}
        {% assign defaults = 'Free Shipping|On orders over $75,Easy Returns|30-day hassle-free returns,Secure Checkout|256-bit SSL encryption,Premium Quality|Crafted with care' | split: ',' %}
        {% for item in defaults %}
          {% assign parts = item | split: '|' %}
          <li class="premium-trust-bar__item">
            <div class="premium-trust-bar__text">
              <h3 class="premium-trust-bar__title">{{ parts[0] }}</h3>
              <p class="premium-trust-bar__desc">{{ parts[1] }}</p>
            </div>
          </li>
        {% endfor %}
      {% endfor %}
    </ul>
  </div>
</section>

{% stylesheet %}
  .premium-trust-bar__list {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  @media screen and (min-width: 750px) {
    .premium-trust-bar__list {
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 2rem;
    }
  }

  .premium-trust-bar__item {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    text-align: left;
  }

  .premium-trust-bar__icon {
    flex-shrink: 0;
    width: 2.5rem;
    height: 2.5rem;
  }

  .premium-trust-bar__icon img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .premium-trust-bar__title {
    font-size: 0.875rem !important;
    font-weight: 600;
    margin: 0 0 0.25rem;
    letter-spacing: 0.02em;
  }

  .premium-trust-bar__desc {
    margin: 0;
    font-size: 0.8125rem;
    opacity: 0.75;
    line-height: 1.5;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Premium Trust Bar",
  "tag": "section",
  "class": "premium-trust-bar-section",
  "max_blocks": 6,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Accessible heading (visually hidden)",
      "default": "Why shop with us"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#f5f5f5"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#1a1a1a"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "trust_item",
      "name": "Trust item",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon"
        },
        {
          "type": "text",
          "id": "icon_alt",
          "label": "Icon alt text"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Free Shipping"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description",
          "default": "On orders over $75"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Premium Trust Bar",
      "blocks": [
        { "type": "trust_item", "settings": { "title": "Free Shipping", "description": "On orders over $75" } },
        { "type": "trust_item", "settings": { "title": "Easy Returns", "description": "30-day hassle-free returns" } },
        { "type": "trust_item", "settings": { "title": "Secure Checkout", "description": "256-bit SSL encryption" } },
        { "type": "trust_item", "settings": { "title": "Premium Quality", "description": "Crafted with care" } }
      ]
    }
  ]
}
{% endschema %}
