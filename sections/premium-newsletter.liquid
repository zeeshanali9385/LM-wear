<section
  class="premium-section premium-newsletter"
  id="PremiumNewsletter-{{ section.id }}"
  style="
    background-color: {{ section.settings.background_color }};
    color: {{ section.settings.text_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    --premium-btn-bg: {{ section.settings.button_background }};
    --premium-btn-text: {{ section.settings.button_text_color }};
  "
>
  <div class="page-width premium-newsletter__inner">
    <div class="premium-newsletter__content">
      {% if section.settings.eyebrow != blank %}
        <span class="premium-section__eyebrow">{{ section.settings.eyebrow }}</span>
      {% endif %}
      {% if section.settings.heading != blank %}
        <h2 class="premium-section__heading">{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.settings.subheading != blank %}
        <p class="premium-section__subheading">{{ section.settings.subheading }}</p>
      {% endif %}
    </div>

    {% form 'customer', class: 'premium-newsletter__form' %}
      <input type="hidden" name="contact[tags]" value="newsletter">
      <div class="premium-newsletter__fields">
        <label class="visually-hidden" for="NewsletterEmail-{{ section.id }}">{{ section.settings.email_label }}</label>
        <input
          type="email"
          id="NewsletterEmail-{{ section.id }}"
          name="contact[email]"
          class="premium-newsletter__input"
          placeholder="{{ section.settings.email_placeholder }}"
          required
          autocomplete="email"
        >
        <button type="submit" class="premium-btn premium-btn--primary premium-newsletter__submit">
          {{ section.settings.button_label }}
        </button>
      </div>
      {% if form.posted_successfully? %}
        <p class="premium-newsletter__status premium-newsletter__status--success" role="status">
          {{ section.settings.success_message }}
        </p>
      {% elsif form.errors %}
        <p class="premium-newsletter__status premium-newsletter__status--error" role="alert">
          {{ form.errors.translated_fields.email | capitalize }} {{ form.errors.messages.email }}
        </p>
      {% endif %}
    {% endform %}

    {% if section.settings.disclaimer != blank %}
      <p class="premium-newsletter__disclaimer">{{ section.settings.disclaimer }}</p>
    {% endif %}
  </div>
</section>

{% stylesheet %}
  .premium-newsletter__inner {
    text-align: center;
  }

  .premium-newsletter__content .premium-section__subheading {
    margin-inline: auto;
  }

  .premium-newsletter__form {
    max-width: 520px;
    margin: 0 auto;
  }

  .premium-newsletter__fields {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  @media screen and (min-width: 750px) {
    .premium-newsletter__fields {
      flex-direction: row;
    }
  }

  .premium-newsletter__input {
    flex: 1;
    padding: 0.875rem 1rem;
    border: 1px solid rgba(0, 0, 0, 0.15);
    background: transparent;
    font: inherit;
    font-size: 0.9375rem;
    color: inherit;
  }

  .premium-newsletter__submit {
    flex-shrink: 0;
    white-space: nowrap;
  }

  .premium-newsletter__status {
    margin: 0.75rem 0 0;
    font-size: 0.875rem;
  }

  .premium-newsletter__status--success {
    color: #1a7f37;
  }

  .premium-newsletter__status--error {
    color: #c41e1e;
  }

  .premium-newsletter__disclaimer {
    margin: 1rem auto 0;
    max-width: 480px;
    font-size: 0.75rem;
    opacity: 0.6;
    line-height: 1.5;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Premium Newsletter",
  "tag": "section",
  "class": "premium-newsletter-section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Stay Connected"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Join Our Newsletter"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Be the first to know about new arrivals, exclusive offers, and style inspiration."
    },
    {
      "type": "text",
      "id": "email_label",
      "label": "Email field label (accessible)",
      "default": "Email address"
    },
    {
      "type": "text",
      "id": "email_placeholder",
      "label": "Email placeholder",
      "default": "Enter your email"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Subscribe"
    },
    {
      "type": "text",
      "id": "success_message",
      "label": "Success message",
      "default": "Thank you for subscribing!"
    },
    {
      "type": "textarea",
      "id": "disclaimer",
      "label": "Disclaimer text",
      "default": "By subscribing, you agree to receive marketing emails. Unsubscribe anytime."
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_background",
      "label": "Button background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text color",
      "default": "#1a1a1a"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 72
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 72
    }
  ],
  "presets": [
    {
      "name": "Premium Newsletter"
    }
  ]
}
{% endschema %}
