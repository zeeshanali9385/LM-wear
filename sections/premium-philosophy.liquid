<section
  class="premium-section premium-philosophy"
  id="PremiumPhilosophy-{{ section.id }}"
  style="
    --premium-philosophy-bg: {{ section.settings.background_color }};
    --premium-philosophy-text: {{ section.settings.text_color }};
    --premium-btn-bg: {{ section.settings.button_background }};
    --premium-btn-text: {{ section.settings.button_text_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="premium-philosophy__shell">
    <div class="premium-philosophy__media" aria-hidden="{{ section.settings.image == blank }}">
      {% if section.settings.image != blank %}
        {{
          section.settings.image
          | image_url: width: 1600
          | image_tag:
            loading: 'lazy',
            widths: '600, 900, 1200, 1600',
            sizes: '(min-width: 750px) 50vw, 100vw',
            alt: section.settings.image_alt | escape
        }}
      {% else %}
        {{ 'lifestyle-1' | placeholder_svg_tag: 'premium-philosophy__placeholder' }}
      {% endif %}
    </div>

    <div class="premium-philosophy__content">
      {% if section.settings.eyebrow != blank %}
        <span class="premium-section__eyebrow beauty-reveal">{{ section.settings.eyebrow }}</span>
      {% endif %}
      {% if section.settings.heading != blank %}
        <h2 class="premium-section__heading beauty-reveal beauty-reveal--delay-1">{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.settings.text != blank %}
        <div class="premium-philosophy__text beauty-reveal beauty-reveal--delay-2">
          {{ section.settings.text }}
        </div>
      {% endif %}
      {% if section.settings.button_label != blank %}
        <a
          href="{{ section.settings.button_link }}"
          class="premium-btn premium-btn--primary beauty-reveal beauty-reveal--delay-3"
        >
          {{ section.settings.button_label }}
        </a>
      {% endif %}
    </div>
  </div>
</section>

{% stylesheet %}
  .premium-philosophy {
    color: var(--premium-philosophy-text, #1c1917);
    background: var(--premium-philosophy-bg, #f3ebe6);
  }

  .premium-philosophy__shell {
    display: grid;
    grid-template-columns: 1fr;
    min-height: 420px;
  }

  @media screen and (min-width: 900px) {
    .premium-philosophy__shell {
      grid-template-columns: 1.05fr 0.95fr;
      min-height: 560px;
    }
  }

  .premium-philosophy__media {
    min-height: 280px;
    overflow: hidden;
    background: var(--beauty-bg-soft, #f7f5f3);
  }

  .premium-philosophy__media img,
  .premium-philosophy__placeholder {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .premium-philosophy__content {
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 2.5rem 1.5rem;
  }

  @media screen and (min-width: 900px) {
    .premium-philosophy__content {
      padding: 4rem 4.5rem;
    }
  }

  .premium-philosophy__text {
    margin: 0 0 2rem;
    max-width: 34rem;
    font-size: 1.0625rem;
    line-height: 1.7;
    color: color-mix(in srgb, var(--premium-philosophy-text, #1c1917) 78%, transparent);
  }

  .premium-philosophy__text p {
    margin: 0 0 1rem;
  }

  .premium-philosophy__text p:last-child {
    margin-bottom: 0;
  }

  @media screen and (max-width: 749px) {
    .premium-philosophy__media {
      min-height: 240px;
      aspect-ratio: 4 / 3;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Premium Philosophy",
  "tag": "section",
  "class": "premium-philosophy-section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Our Philosophy"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Pure beauty, chosen with care"
    },
    {
      "type": "richtext",
      "id": "text",
      "label": "Text",
      "default": "<p>Beauty should feel simple, honest, and easy to trust. Every detail brings clarity and ease to everyday rituals.</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Our Story"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "image_alt",
      "label": "Image alt text"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#f3ebe6"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#1c1917"
    },
    {
      "type": "color",
      "id": "button_background",
      "label": "Button background",
      "default": "#1c1917"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Premium Philosophy"
    }
  ]
}
{% endschema %}
