<section
  class="premium-section premium-values"
  id="PremiumValues-{{ section.id }}"
  style="
    background-color: {{ section.settings.background_color }};
    color: {{ section.settings.text_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="page-width">
    <header class="premium-values__header">
      {% if section.settings.eyebrow != blank %}
        <span class="premium-section__eyebrow">{{ section.settings.eyebrow }}</span>
      {% endif %}
      {% if section.settings.heading != blank %}
        <h2 class="premium-section__heading">{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.settings.subheading != blank %}
        <p class="premium-section__subheading">{{ section.settings.subheading }}</p>
      {% endif %}
    </header>

    <ul class="premium-values__grid" role="list">
      {% for block in section.blocks %}
        <li class="premium-values__item" {{ block.shopify_attributes }}>
          {% if block.settings.icon != blank %}
            <div class="premium-values__icon">
              {{
                block.settings.icon
                | image_url: width: 96
                | image_tag:
                  loading: 'lazy',
                  width: 48,
                  height: 48,
                  alt: block.settings.title | escape
              }}
            </div>
          {% else %}
            <div class="premium-values__icon premium-values__icon--mark" aria-hidden="true">
              <span></span>
            </div>
          {% endif %}
          {% if block.settings.title != blank %}
            <h3 class="premium-values__title">{{ block.settings.title }}</h3>
          {% endif %}
          {% if block.settings.description != blank %}
            <p class="premium-values__desc">{{ block.settings.description }}</p>
          {% endif %}
        </li>
      {% endfor %}
    </ul>
  </div>
</section>

{% stylesheet %}
  .premium-values__header {
    text-align: center;
    margin-bottom: 2.75rem;
  }

  .premium-values__header .premium-section__subheading {
    margin-inline: auto;
  }

  .premium-values__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  @media screen and (min-width: 750px) {
    .premium-values__grid {
      grid-template-columns: repeat(3, 1fr);
      gap: 2.5rem;
    }
  }

  .premium-values__item {
    text-align: center;
    padding: 1.75rem 1.25rem;
    border: 1px solid var(--beauty-line, #e5dfd8);
    background: color-mix(in srgb, #fff 70%, transparent);
    border-radius: 2px;
    transition: border-color 0.3s ease, transform 0.4s var(--beauty-ease, ease);
  }

  .premium-values__item:hover {
    border-color: var(--beauty-accent-soft, #c9a99a);
    transform: translateY(-4px);
  }

  .premium-values__icon {
    width: 3rem;
    height: 3rem;
    margin: 0 auto 1.25rem;
  }

  .premium-values__icon img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .premium-values__icon--mark {
    display: grid;
    place-items: center;
  }

  .premium-values__icon--mark span {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--beauty-accent, #8f6a5b);
    box-shadow: 0 0 0 8px color-mix(in srgb, var(--beauty-accent, #8f6a5b) 16%, transparent);
  }

  .premium-values__title {
    margin: 0 0 0.75rem;
    font-size: 1.25rem !important;
    font-weight: 500;
  }

  .premium-values__desc {
    margin: 0 auto;
    max-width: 28ch;
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--beauty-muted, #6b6560);
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Premium Values",
  "tag": "section",
  "class": "premium-values-section",
  "max_blocks": 6,
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Our Promise"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Beauty you can trust"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Clean formulas, thoughtful ingredients, and rituals made for everyday glow."
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#1c1917"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 72
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 72
    }
  ],
  "blocks": [
    {
      "type": "value",
      "name": "Value",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Cruelty-Free"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Always and forever — compassion is true beauty."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Premium Values",
      "blocks": [
        {
          "type": "value",
          "settings": {
            "title": "Cruelty-Free",
            "description": "We're cruelty-free, always and forever, because we believe compassion is the true beauty."
          }
        },
        {
          "type": "value",
          "settings": {
            "title": "Paraben-Free",
            "description": "Clean, safe beauty — formulated without parabens for everyday confidence."
          }
        },
        {
          "type": "value",
          "settings": {
            "title": "Earth-Conscious",
            "description": "Our commitment to the planet is present in every step of our product journey."
          }
        }
      ]
    }
  ]
}
{% endschema %}
