<section
  class="premium-section premium-collection-banner"
  id="PremiumCollectionBanner-{{ section.id }}"
  style="
    --premium-banner-min-height: {{ section.settings.min_height }}px;
    --premium-banner-overlay: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    --premium-banner-text: {{ section.settings.text_color }};
    --premium-banner-overlay-color: {{ section.settings.overlay_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  {% liquid
    assign banner_image = section.settings.image
    if banner_image == blank and collection.image
      assign banner_image = collection.image
    endif
  %}

  <div class="premium-collection-banner__media" aria-hidden="true">
    {% if banner_image != blank %}
      {{
        banner_image
        | image_url: width: 2400
        | image_tag:
          loading: 'eager',
          fetchpriority: 'high',
          widths: '750, 1100, 1500, 2000, 2400',
          sizes: '100vw',
          alt: collection.title | escape
      }}
    {% else %}
      <div class="premium-collection-banner__fallback"></div>
    {% endif %}
    <div class="premium-collection-banner__overlay"></div>
  </div>

  <div class="premium-collection-banner__content">
    <div class="page-width">
      {% if section.settings.show_breadcrumb %}
        <nav class="premium-collection-banner__crumbs beauty-reveal" aria-label="Breadcrumb">
          <a href="{{ routes.root_url }}">Home</a>
          <span aria-hidden="true">/</span>
          <a href="{{ routes.collections_url }}">Shop</a>
          <span aria-hidden="true">/</span>
          <span>{{ collection.title }}</span>
        </nav>
      {% endif %}

      {% if section.settings.eyebrow != blank %}
        <span class="premium-section__eyebrow beauty-reveal beauty-reveal--delay-1">{{ section.settings.eyebrow }}</span>
      {% endif %}

      <h1 class="premium-collection-banner__title beauty-reveal beauty-reveal--delay-1">
        {{ collection.title }}
      </h1>

      {% if section.settings.show_description and collection.description != blank %}
        <div class="premium-collection-banner__desc beauty-reveal beauty-reveal--delay-2">
          {{ collection.description }}
        </div>
      {% elsif section.settings.fallback_text != blank %}
        <p class="premium-collection-banner__desc beauty-reveal beauty-reveal--delay-2">
          {{ section.settings.fallback_text }}
        </p>
      {% endif %}

      {% if section.settings.show_count %}
        <p class="premium-collection-banner__count beauty-reveal beauty-reveal--delay-3">
          {{ collection.products_count }}
          {% if collection.products_count == 1 %}product{% else %}products{% endif %}
        </p>
      {% endif %}
    </div>
  </div>
</section>

{% stylesheet %}
  .premium-collection-banner {
    position: relative;
    display: flex;
    align-items: flex-end;
    min-height: var(--premium-banner-min-height, 280px);
    overflow: hidden;
    color: var(--premium-banner-text, #1c1917);
  }

  .premium-collection-banner__media {
    position: absolute;
    inset: 0;
  }

  .premium-collection-banner__media img,
  .premium-collection-banner__fallback {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .premium-collection-banner__fallback {
    background:
      radial-gradient(80% 80% at 80% 20%, rgba(201, 169, 154, 0.35) 0%, transparent 60%),
      linear-gradient(135deg, #f7f5f3 0%, #f3ebe6 100%);
  }

  .premium-collection-banner__overlay {
    position: absolute;
    inset: 0;
    background:
      linear-gradient(
        180deg,
        color-mix(in srgb, var(--premium-banner-overlay-color, #1c1917) 0%, transparent) 0%,
        color-mix(in srgb, var(--premium-banner-overlay-color, #1c1917) 45%, transparent) 100%
      );
    opacity: var(--premium-banner-overlay, 0.35);
  }

  .premium-collection-banner:has(.premium-collection-banner__fallback) .premium-collection-banner__overlay {
    opacity: 0.08;
  }

  .premium-collection-banner__content {
    position: relative;
    z-index: 1;
    width: 100%;
    padding-block: 2.5rem 2.75rem;
  }

  .premium-collection-banner__crumbs {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.45rem;
    margin-bottom: 1rem;
    font-size: 0.6875rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    opacity: 0.8;
  }

  .premium-collection-banner__crumbs a {
    color: inherit;
    text-decoration: none;
  }

  .premium-collection-banner__crumbs a:hover {
    opacity: 0.7;
  }

  .premium-collection-banner__title {
    margin: 0 0 0.85rem;
    font-size: clamp(2rem, 4vw, 3.25rem) !important;
    line-height: 1.08;
    letter-spacing: -0.03em;
    font-weight: 500;
  }

  .premium-collection-banner__desc {
    margin: 0;
    max-width: 40rem;
    font-size: 1rem;
    line-height: 1.65;
    opacity: 0.9;
  }

  .premium-collection-banner__desc p {
    margin: 0 0 0.75rem;
  }

  .premium-collection-banner__desc p:last-child {
    margin-bottom: 0;
  }

  .premium-collection-banner__count {
    margin: 1rem 0 0;
    font-size: 0.75rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    opacity: 0.7;
  }

  @media screen and (max-width: 749px) {
    .premium-collection-banner {
      min-height: 220px;
    }

    .premium-collection-banner__content {
      padding-block: 2rem 2.25rem;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Premium Collection Banner",
  "tag": "section",
  "class": "premium-collection-banner-section",
  "enabled_on": {
    "templates": ["collection"]
  },
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Collection"
    },
    {
      "type": "textarea",
      "id": "fallback_text",
      "label": "Fallback description",
      "default": "Thoughtfully curated products for everyday glow and comfort."
    },
    {
      "type": "checkbox",
      "id": "show_description",
      "label": "Show collection description",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_breadcrumb",
      "label": "Show breadcrumb",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_count",
      "label": "Show product count",
      "default": true
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Banner image",
      "info": "Defaults to collection image when empty"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay color",
      "default": "#1c1917"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "label": "Overlay opacity",
      "default": 25
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#1c1917"
    },
    {
      "type": "range",
      "id": "min_height",
      "min": 180,
      "max": 520,
      "step": 20,
      "unit": "px",
      "label": "Minimum height",
      "default": 300
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 0
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 0
    }
  ],
  "presets": [
    {
      "name": "Premium Collection Banner"
    }
  ]
}
{% endschema %}
