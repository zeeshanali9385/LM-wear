{% liquid
  assign blog = section.settings.blog
  assign posts_to_show = section.settings.posts_to_show
%}

<section
  class="premium-section premium-blog"
  id="PremiumBlog-{{ section.id }}"
  style="
    background-color: {{ section.settings.background_color }};
    color: {{ section.settings.text_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    --premium-card-ratio: {{ section.settings.image_ratio }};
  "
>
  <div class="page-width">
    <header class="premium-blog__header">
      <div>
        {% if section.settings.eyebrow != blank %}
          <span class="premium-section__eyebrow">{{ section.settings.eyebrow }}</span>
        {% endif %}
        {% if section.settings.heading != blank %}
          <h2 class="premium-section__heading">{{ section.settings.heading }}</h2>
        {% endif %}
        {% if section.settings.subheading != blank %}
          <p class="premium-section__subheading">{{ section.settings.subheading }}</p>
        {% endif %}
      </div>
      {% if section.settings.button_label != blank %}
        <a href="{{ section.settings.button_link | default: blog.url }}" class="premium-btn premium-btn--secondary">
          {{ section.settings.button_label }}
        </a>
      {% endif %}
    </header>

    <div class="premium-blog__grid" role="list">
      {% if blog != blank and blog.articles_count > 0 %}
        {% for article in blog.articles limit: posts_to_show %}
          <article class="premium-card premium-blog__item" role="listitem">
            <a href="{{ article.url }}" class="premium-blog__link">
              <div class="premium-card__image">
                {% if article.image %}
                  {{
                    article.image
                    | image_url: width: 900
                    | image_tag:
                      loading: 'lazy',
                      widths: '400, 600, 900',
                      sizes: '(min-width: 750px) 33vw, 100vw',
                      alt: article.image.alt | default: article.title | escape
                  }}
                {% else %}
                  {{ 'image' | placeholder_svg_tag }}
                {% endif %}
              </div>
              <div class="premium-blog__meta">
                <time class="premium-blog__date" datetime="{{ article.published_at | date: '%Y-%m-%d' }}">
                  {{ article.published_at | date: format: 'abbreviated_date' }}
                </time>
                <h3 class="premium-blog__title">{{ article.title }}</h3>
                {% if section.settings.show_excerpt %}
                  <p class="premium-blog__excerpt">{{ article.excerpt_or_content | strip_html | truncate: 120 }}</p>
                {% endif %}
              </div>
            </a>
          </article>
        {% endfor %}
      {% else %}
        {% for i in (1..3) %}
          <article class="premium-card premium-blog__item" role="listitem">
            <div class="premium-card__image">{{ 'image' | placeholder_svg_tag }}</div>
            <div class="premium-blog__meta">
              <h3 class="premium-blog__title">Blog post {{ i }}</h3>
            </div>
          </article>
        {% endfor %}
      {% endif %}
    </div>
  </div>
</section>

{% stylesheet %}
  .premium-blog__header {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1.5rem;
    margin-bottom: 2.5rem;
  }

  .premium-blog__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  @media screen and (min-width: 750px) {
    .premium-blog__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .premium-blog__link {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .premium-blog__meta {
    padding: 1rem 0.25rem 0;
  }

  .premium-blog__date {
    display: block;
    font-size: 0.75rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    opacity: 0.6;
    margin-bottom: 0.5rem;
  }

  .premium-blog__title {
    font-size: 1.0625rem !important;
    margin: 0 0 0.5rem;
    font-weight: 500;
  }

  .premium-blog__excerpt {
    margin: 0;
    font-size: 0.875rem;
    opacity: 0.75;
    line-height: 1.5;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Premium Blog",
  "tag": "section",
  "class": "premium-blog-section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Journal"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "From the Blog"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Tips, trends, and stories from our world."
    },
    {
      "type": "blog",
      "id": "blog",
      "label": "Blog"
    },
    {
      "type": "range",
      "id": "posts_to_show",
      "min": 2,
      "max": 6,
      "step": 1,
      "label": "Posts to show",
      "default": 3
    },
    {
      "type": "checkbox",
      "id": "show_excerpt",
      "label": "Show excerpt",
      "default": true
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "View all button label",
      "default": "Read More"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "View all button link"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Image ratio",
      "options": [
        { "value": "16/9", "label": "Landscape" },
        { "value": "4/5", "label": "Portrait" },
        { "value": "3/2", "label": "Classic" }
      ],
      "default": "16/9"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#1a1a1a"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 64
    }
  ],
  "presets": [
    {
      "name": "Premium Blog"
    }
  ]
}
{% endschema %}
