{% liquid
  if section.settings.background_color != blank
    render 'contrast-override', background_color: section.settings.background_color, section_id: section.id
  endif
%}

<footer
  class="premium-footer{% if section.settings.background_color != blank %} color-custom-{{ section.id }}{% endif %}"
  style="
    --premium-footer-bg: {{ section.settings.background_color }};
    --premium-footer-text: {{ section.settings.text_color }};
    --premium-footer-muted: {{ section.settings.muted_text_color }};
    --premium-footer-border: {{ section.settings.border_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="page-width">
    <div class="premium-footer__grid">
      <div class="premium-footer__brand">
        {% if section.settings.logo != blank %}
          <a href="{{ routes.root_url }}" class="premium-footer__logo-link">
            {{
              section.settings.logo
              | image_url: width: 280
              | image_tag:
                loading: 'lazy',
                widths: '120, 180, 240, 280',
                sizes: '160px',
                class: 'premium-footer__logo',
                alt: section.settings.logo_alt | default: shop.name | escape
            }}
          </a>
        {% else %}
          <a href="{{ routes.root_url }}" class="premium-footer__brand-name">{{ section.settings.brand_name | default: shop.name }}</a>
        {% endif %}

        {% if section.settings.brand_description != blank %}
          <p class="premium-footer__description">{{ section.settings.brand_description }}</p>
        {% endif %}

        {% if section.settings.show_social %}
          <ul class="premium-footer__social" role="list">
            {% if section.settings.instagram_url != blank %}
              <li>
                <a href="{{ section.settings.instagram_url }}" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
                  <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true"><rect x="2" y="2" width="20" height="20" rx="5"/><circle cx="12" cy="12" r="4"/><circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none"/></svg>
                </a>
              </li>
            {% endif %}
            {% if section.settings.facebook_url != blank %}
              <li>
                <a href="{{ section.settings.facebook_url }}" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
                  <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true"><path d="M14 9h3V6h-3c-2.2 0-4 1.8-4 4v2H7v3h3v7h3v-7h2.5l.5-3H13v-2c0-.6.4-1 1-1z"/></svg>
                </a>
              </li>
            {% endif %}
            {% if section.settings.tiktok_url != blank %}
              <li>
                <a href="{{ section.settings.tiktok_url }}" target="_blank" rel="noopener noreferrer" aria-label="TikTok">
                  <svg viewBox="0 0 24 24" width="18" height="18" fill="currentColor" aria-hidden="true"><path d="M16.5 3c.4 2.2 1.7 3.9 3.5 4.8V11c-1.8-.1-3.4-.7-4.8-1.6v6.1c0 3.2-2.6 5.8-5.8 5.8S3.6 18.7 3.6 15.5s2.6-5.8 5.8-5.8c.3 0 .6 0 .9.1v3.3c-.3-.1-.6-.2-.9-.2-1.4 0-2.6 1.2-2.6 2.6s1.2 2.6 2.6 2.6 2.6-1.2 2.6-2.6V3h3.5z"/></svg>
                </a>
              </li>
            {% endif %}
          </ul>
        {% endif %}
      </div>

      <div class="premium-footer__column">
        <h2 class="premium-footer__heading">{{ section.settings.quick_links_heading }}</h2>
        {% if section.settings.quick_links_menu != blank and section.settings.quick_links_menu.links.size > 0 %}
          <ul class="premium-footer__links" role="list">
            {% for link in section.settings.quick_links_menu.links %}
              <li><a href="{{ link.url }}">{{ link.title }}</a></li>
            {% endfor %}
          </ul>
        {% else %}
          <ul class="premium-footer__links" role="list">
            <li><a href="{{ routes.all_products_collection_url }}">Shop All</a></li>
            <li><a href="{{ routes.collections_url }}">Collections</a></li>
            <li><a href="{{ routes.search_url }}">Search</a></li>
          </ul>
        {% endif %}
      </div>

      <div class="premium-footer__column">
        <h2 class="premium-footer__heading">{{ section.settings.support_links_heading }}</h2>
        {% if section.settings.support_links_menu != blank and section.settings.support_links_menu.links.size > 0 %}
          <ul class="premium-footer__links" role="list">
            {% for link in section.settings.support_links_menu.links %}
              <li><a href="{{ link.url }}">{{ link.title }}</a></li>
            {% endfor %}
          </ul>
        {% else %}
          <ul class="premium-footer__links" role="list">
            {% for policy in shop.policies %}
              <li><a href="{{ policy.url }}">{{ policy.title }}</a></li>
            {% endfor %}
          </ul>
        {% endif %}
      </div>
    </div>

    <div class="premium-footer__bottom">
      <p class="premium-footer__copyright">
        &copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. {{ section.settings.copyright_text }}
      </p>
      {% if section.settings.show_payment_icons and shop.enabled_payment_types.size > 0 %}
        <ul class="premium-footer__payments" role="list">
          {% for type in shop.enabled_payment_types %}
            <li>{{ type | payment_type_svg_tag: class: 'premium-footer__payment-icon' }}</li>
          {% endfor %}
        </ul>
      {% endif %}
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Premium Footer",
  "enabled_on": {
    "groups": ["footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Brand"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "text",
      "id": "logo_alt",
      "label": "Logo alt text"
    },
    {
      "type": "text",
      "id": "brand_name",
      "label": "Brand name",
      "default": "LM Wear"
    },
    {
      "type": "textarea",
      "id": "brand_description",
      "label": "Brand description",
      "default": "Premium beauty and innerwear essentials — crafted for comfort, confidence, and everyday elegance."
    },
    {
      "type": "header",
      "content": "Quick links"
    },
    {
      "type": "text",
      "id": "quick_links_heading",
      "label": "Heading",
      "default": "Shop"
    },
    {
      "type": "link_list",
      "id": "quick_links_menu",
      "label": "Menu"
    },
    {
      "type": "header",
      "content": "Support & policies"
    },
    {
      "type": "text",
      "id": "support_links_heading",
      "label": "Heading",
      "default": "Help"
    },
    {
      "type": "link_list",
      "id": "support_links_menu",
      "label": "Menu"
    },
    {
      "type": "header",
      "content": "Social media"
    },
    {
      "type": "checkbox",
      "id": "show_social",
      "label": "Show social icons",
      "default": true
    },
    {
      "type": "url",
      "id": "instagram_url",
      "label": "Instagram URL"
    },
    {
      "type": "url",
      "id": "facebook_url",
      "label": "Facebook URL"
    },
    {
      "type": "url",
      "id": "tiktok_url",
      "label": "TikTok URL"
    },
    {
      "type": "header",
      "content": "Bottom bar"
    },
    {
      "type": "text",
      "id": "copyright_text",
      "label": "Copyright note",
      "default": "All rights reserved."
    },
    {
      "type": "checkbox",
      "id": "show_payment_icons",
      "label": "Show payment icons",
      "default": true
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#fafafa"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#1a1a1a"
    },
    {
      "type": "color",
      "id": "muted_text_color",
      "label": "Muted text",
      "default": "#666666"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Border",
      "default": "#e5e5e5"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 32,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 24,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 32
    }
  ],
  "presets": [
    {
      "name": "Premium Footer"
    }
  ]
}
{% endschema %}
