<section
  class="premium-section premium-trust-bar"
  id="PremiumTrustBar-{{ section.id }}"
  style="
    background-color: {{ section.settings.background_color }};
    color: {{ section.settings.text_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  "
  aria-label="{{ section.settings.heading | default: 'Trust badges' | escape }}"
>
  <div class="page-width">
    {% if section.settings.heading != blank %}
      <h2 class="visually-hidden">{{ section.settings.heading }}</h2>
    {% endif %}
    <ul class="premium-trust-bar__list" role="list">
      {% for block in section.blocks %}
        <li class="premium-trust-bar__item" {{ block.shopify_attributes }}>
          <div class="premium-trust-bar__icon">
            {% if block.settings.icon != blank %}
              {{
                block.settings.icon
                | image_url: width: 80
                | image_tag:
                  loading: 'lazy',
                  width: 40,
                  height: 40,
                  alt: block.settings.icon_alt | default: block.settings.title | escape
              }}
            {% else %}
              <span class="premium-trust-bar__glyph" aria-hidden="true" data-icon="{{ block.settings.icon_style | default: 'leaf' }}">
                {% case block.settings.icon_style %}
                  {% when 'truck' %}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M3 7h11v8H3z"/><path d="M14 10h4l3 3v2h-7"/><circle cx="7" cy="17" r="1.5"/><circle cx="17" cy="17" r="1.5"/></svg>
                  {% when 'return' %}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M9 7H5v4"/><path d="M5 11a7 7 0 1 0 2-4.9L5 7"/></svg>
                  {% when 'shield' %}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 3l7 3v5c0 4.5-3 7.5-7 9-4-1.5-7-4.5-7-9V6l7-3z"/><path d="M9 12l2 2 4-4"/></svg>
                  {% else %}
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 3c2.5 3 4 5.2 4 7.5a4 4 0 1 1-8 0C8 8.2 9.5 6 12 3z"/><path d="M9 18c1 .8 2 1.2 3 1.2s2-.4 3-1.2"/></svg>
                {% endcase %}
              </span>
            {% endif %}
          </div>
          <div class="premium-trust-bar__text">
            {% if block.settings.title != blank %}
              <h3 class="premium-trust-bar__title">{{ block.settings.title }}</h3>
            {% endif %}
            {% if block.settings.description != blank %}
              <p class="premium-trust-bar__desc">{{ block.settings.description }}</p>
            {% endif %}
          </div>
        </li>
      {% else %}
        {% assign defaults = 'Free Shipping|On orders over $75,Easy Returns|30-day hassle-free returns,Secure Checkout|256-bit SSL encryption,Premium Quality|Crafted with care' | split: ',' %}
        {% for item in defaults %}
          {% assign parts = item | split: '|' %}
          <li class="premium-trust-bar__item">
            <div class="premium-trust-bar__icon">
              <span class="premium-trust-bar__glyph" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M12 3c2.5 3 4 5.2 4 7.5a4 4 0 1 1-8 0C8 8.2 9.5 6 12 3z"/></svg>
              </span>
            </div>
            <div class="premium-trust-bar__text">
              <h3 class="premium-trust-bar__title">{{ parts[0] }}</h3>
              <p class="premium-trust-bar__desc">{{ parts[1] }}</p>
            </div>
          </li>
        {% endfor %}
      {% endfor %}
    </ul>
  </div>
</section>

{% stylesheet %}
  .premium-trust-bar__list {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    list-style: none;
    margin: 0;
    padding: 0;
  }

  @media screen and (min-width: 750px) {
    .premium-trust-bar__list {
      grid-template-columns: repeat(4, 1fr);
      gap: 1.5rem;
    }
  }

  .premium-trust-bar__item {
    display: flex;
    align-items: flex-start;
    gap: 0.9rem;
    text-align: left;
    padding: 1rem 0.85rem;
    border: 1px solid var(--beauty-line, #e5dfd8);
    background: color-mix(in srgb, #fff 70%, transparent);
    border-radius: 2px;
  }

  .premium-trust-bar__icon {
    flex-shrink: 0;
    width: 2.5rem;
    height: 2.5rem;
    display: grid;
    place-items: center;
  }

  .premium-trust-bar__icon img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .premium-trust-bar__glyph {
    display: grid;
    place-items: center;
    width: 2.5rem;
    height: 2.5rem;
    border-radius: 50%;
    background: var(--beauty-bg-blush, #f3ebe6);
    color: var(--beauty-accent, #8f6a5b);
  }

  .premium-trust-bar__glyph svg {
    width: 1.2rem;
    height: 1.2rem;
  }

  .premium-trust-bar__title {
    font-size: 0.875rem !important;
    font-weight: 600;
    margin: 0 0 0.25rem;
    letter-spacing: 0.02em;
  }

  .premium-trust-bar__desc {
    margin: 0;
    font-size: 0.8125rem;
    opacity: 0.75;
    line-height: 1.5;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Premium Trust Bar",
  "tag": "section",
  "class": "premium-trust-bar-section",
  "max_blocks": 6,
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Accessible heading (visually hidden)",
      "default": "Why shop with us"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#f5f5f5"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#1a1a1a"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 40
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "trust_item",
      "name": "Trust item",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Custom icon image"
        },
        {
          "type": "text",
          "id": "icon_alt",
          "label": "Icon alt text"
        },
        {
          "type": "select",
          "id": "icon_style",
          "label": "Built-in icon",
          "options": [
            { "value": "leaf", "label": "Leaf" },
            { "value": "truck", "label": "Shipping" },
            { "value": "return", "label": "Returns" },
            { "value": "shield", "label": "Secure" }
          ],
          "default": "leaf",
          "info": "Used when no custom icon image is set"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Free Shipping"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description",
          "default": "On orders over $75"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Premium Trust Bar",
      "blocks": [
        { "type": "trust_item", "settings": { "title": "Free Shipping", "description": "On orders over $75", "icon_style": "truck" } },
        { "type": "trust_item", "settings": { "title": "Easy Returns", "description": "30-day hassle-free returns", "icon_style": "return" } },
        { "type": "trust_item", "settings": { "title": "Secure Checkout", "description": "256-bit SSL encryption", "icon_style": "shield" } },
        { "type": "trust_item", "settings": { "title": "Premium Quality", "description": "Crafted with care", "icon_style": "leaf" } }
      ]
    }
  ]
}
{% endschema %}
