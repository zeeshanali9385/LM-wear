<section
  class="premium-section premium-collection-grid"
  id="PremiumCollectionGrid-{{ section.id }}"
  style="
    background-color: {{ section.settings.background_color }};
    color: {{ section.settings.text_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
    --premium-grid-cols: {{ section.settings.columns }};
    --premium-grid-cols-mobile: {{ section.settings.columns_mobile }};
    --premium-card-ratio: {{ section.settings.image_ratio }};
  "
>
  <div class="page-width">
    <header class="premium-collection-grid__header">
      {% if section.settings.eyebrow != blank %}
        <span class="premium-section__eyebrow">{{ section.settings.eyebrow }}</span>
      {% endif %}
      {% if section.settings.heading != blank %}
        <h2 class="premium-section__heading">{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.settings.subheading != blank %}
        <p class="premium-section__subheading">{{ section.settings.subheading }}</p>
      {% endif %}
    </header>

    <div class="premium-collection-grid__grid" role="list">
      {% if section.blocks.size > 0 %}
        {% for block in section.blocks %}
          {% liquid
            assign item_title = block.settings.title
            if item_title == blank and block.settings.collection != blank
              assign item_title = block.settings.collection.title
            endif
          %}
          <article class="premium-card premium-collection-grid__item" role="listitem" {{ block.shopify_attributes }}>
            <a href="{{ block.settings.collection.url | default: block.settings.link }}" class="premium-collection-grid__link">
              <div class="premium-card__image">
                {% if block.settings.image != blank %}
                  {{
                    block.settings.image
                    | image_url: width: 800
                    | image_tag:
                      loading: 'lazy',
                      widths: '300, 400, 600, 800',
                      sizes: '(min-width: 750px) 25vw, 50vw',
                      alt: block.settings.image_alt | default: block.settings.title | escape
                  }}
                {% elsif block.settings.collection.featured_image %}
                  {{
                    block.settings.collection.featured_image
                    | image_url: width: 800
                    | image_tag:
                      loading: 'lazy',
                      widths: '300, 400, 600, 800',
                      sizes: '(min-width: 750px) 25vw, 50vw',
                      alt: block.settings.title | escape
                  }}
                {% else %}
                  {{ 'collection-1' | placeholder_svg_tag }}
                {% endif %}
              </div>
              <div class="premium-collection-grid__meta">
                <h3 class="premium-collection-grid__title">{{ item_title }}</h3>
                {% if block.settings.description != blank %}
                  <p class="premium-collection-grid__desc">{{ block.settings.description }}</p>
                {% endif %}
              </div>
            </a>
          </article>
        {% endfor %}
      {% else %}
        {% for i in (1..4) %}
          <article class="premium-card premium-collection-grid__item" role="listitem">
            <div class="premium-card__image">{{ 'collection-' | append: i | placeholder_svg_tag }}</div>
            <div class="premium-collection-grid__meta">
              <h3 class="premium-collection-grid__title">Collection {{ i }}</h3>
            </div>
          </article>
        {% endfor %}
      {% endif %}
    </div>

    {% if section.settings.button_label != blank %}
      <div class="premium-collection-grid__cta">
        <a href="{{ section.settings.button_link }}" class="premium-btn premium-btn--secondary">
          {{ section.settings.button_label }}
        </a>
      </div>
    {% endif %}
  </div>
</section>

{% stylesheet %}
  .premium-collection-grid__header {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .premium-collection-grid__header .premium-section__subheading {
    margin-inline: auto;
  }

  .premium-collection-grid__grid {
    display: grid;
    grid-template-columns: repeat(var(--premium-grid-cols-mobile, 2), 1fr);
    gap: 1rem;
  }

  @media screen and (min-width: 750px) {
    .premium-collection-grid__grid {
      grid-template-columns: repeat(var(--premium-grid-cols, 4), 1fr);
      gap: 1.5rem;
    }
  }

  .premium-collection-grid__link {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .premium-collection-grid__meta {
    padding: 1rem 0.25rem 0;
  }

  .premium-collection-grid__title {
    font-size: 1rem !important;
    margin: 0 0 0.25rem;
    font-weight: 500;
  }

  .premium-collection-grid__desc {
    margin: 0;
    font-size: 0.875rem;
    opacity: 0.7;
  }

  .premium-collection-grid__cta {
    text-align: center;
    margin-top: 2.5rem;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Premium Collection Grid",
  "tag": "section",
  "class": "premium-collection-grid-section",
  "max_blocks": 8,
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Shop by Category"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Curated Collections"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Explore our handpicked categories designed for every moment."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "View All Collections"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button link"
    },
    {
      "type": "range",
      "id": "columns",
      "min": 2,
      "max": 4,
      "step": 1,
      "label": "Columns (desktop)",
      "default": 4
    },
    {
      "type": "select",
      "id": "columns_mobile",
      "label": "Columns (mobile)",
      "options": [
        { "value": "1", "label": "1" },
        { "value": "2", "label": "2" }
      ],
      "default": "2"
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Image ratio",
      "options": [
        { "value": "1/1", "label": "Square" },
        { "value": "4/5", "label": "Portrait" },
        { "value": "3/4", "label": "Tall portrait" },
        { "value": "16/9", "label": "Landscape" }
      ],
      "default": "4/5"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#1a1a1a"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 64
    }
  ],
  "blocks": [
    {
      "type": "collection",
      "name": "Collection",
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Collection"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "info": "Leave blank to use collection title"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Custom image",
          "info": "Overrides collection featured image"
        },
        {
          "type": "text",
          "id": "image_alt",
          "label": "Image alt text"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Custom link",
          "info": "Overrides collection URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Premium Collection Grid",
      "blocks": [
        { "type": "collection" },
        { "type": "collection" },
        { "type": "collection" },
        { "type": "collection" }
      ]
    }
  ]
}
{% endschema %}
