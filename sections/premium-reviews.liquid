<section
  class="premium-section premium-reviews"
  id="PremiumReviews-{{ section.id }}"
  style="
    background-color: {{ section.settings.background_color }};
    color: {{ section.settings.text_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  "
>
  <div class="page-width">
    <header class="premium-reviews__header">
      {% if section.settings.eyebrow != blank %}
        <span class="premium-section__eyebrow">{{ section.settings.eyebrow }}</span>
      {% endif %}
      {% if section.settings.heading != blank %}
        <h2 class="premium-section__heading">{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.settings.subheading != blank %}
        <p class="premium-section__subheading">{{ section.settings.subheading }}</p>
      {% endif %}
    </header>

    <div class="premium-reviews__grid" role="list">
      {% for block in section.blocks %}
        <article class="premium-reviews__card" role="listitem" {{ block.shopify_attributes }}>
          <div class="premium-reviews__stars" aria-label="{{ block.settings.rating }} out of 5 stars">
            {% for i in (1..5) %}
              <span class="premium-reviews__star{% if i > block.settings.rating %} premium-reviews__star--empty{% endif %}" aria-hidden="true">★</span>
            {% endfor %}
          </div>
          {% if block.settings.quote != blank %}
            <blockquote class="premium-reviews__quote">
              <p>{{ block.settings.quote }}</p>
            </blockquote>
          {% endif %}
          <footer class="premium-reviews__author">
            {% if block.settings.author_image != blank %}
              {{
                block.settings.author_image
                | image_url: width: 80
                | image_tag:
                  loading: 'lazy',
                  width: 40,
                  height: 40,
                  class: 'premium-reviews__avatar',
                  alt: block.settings.author_name | escape
              }}
            {% endif %}
            <div>
              {% if block.settings.author_name != blank %}
                <cite class="premium-reviews__name">{{ block.settings.author_name }}</cite>
              {% endif %}
              {% if block.settings.author_title != blank %}
                <span class="premium-reviews__title">{{ block.settings.author_title }}</span>
              {% endif %}
            </div>
          </footer>
        </article>
      {% else %}
        {% for i in (1..3) %}
          <article class="premium-reviews__card" role="listitem">
            <div class="premium-reviews__stars" aria-hidden="true">
              {% for j in (1..5) %}<span class="premium-reviews__star">★</span>{% endfor %}
            </div>
            <blockquote class="premium-reviews__quote"><p>Absolutely love the quality. Will definitely order again!</p></blockquote>
            <footer class="premium-reviews__author">
              <cite class="premium-reviews__name">Happy Customer</cite>
            </footer>
          </article>
        {% endfor %}
      {% endfor %}
    </div>
  </div>
</section>

{% stylesheet %}
  .premium-reviews__header {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .premium-reviews__header .premium-section__subheading {
    margin-inline: auto;
  }

  .premium-reviews__grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
  }

  @media screen and (min-width: 750px) {
    .premium-reviews__grid {
      grid-template-columns: repeat(3, 1fr);
    }
  }

  .premium-reviews__card {
    padding: 1.75rem;
    border: 1px solid rgba(0, 0, 0, 0.08);
    background: rgba(255, 255, 255, 0.5);
  }

  .premium-reviews__stars {
    margin-bottom: 1rem;
    font-size: 0.875rem;
    letter-spacing: 0.1em;
    color: #c9a227;
  }

  .premium-reviews__star--empty {
    opacity: 0.25;
  }

  .premium-reviews__quote {
    margin: 0 0 1.25rem;
    font-style: italic;
  }

  .premium-reviews__quote p {
    margin: 0;
    font-size: 0.9375rem;
    line-height: 1.6;
  }

  .premium-reviews__author {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .premium-reviews__avatar {
    border-radius: 50%;
    object-fit: cover;
  }

  .premium-reviews__name {
    display: block;
    font-style: normal;
    font-weight: 600;
    font-size: 0.875rem;
  }

  .premium-reviews__title {
    display: block;
    font-size: 0.75rem;
    opacity: 0.65;
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Premium Reviews",
  "tag": "section",
  "class": "premium-reviews-section",
  "max_blocks": 6,
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Testimonials"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What Our Customers Say"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Real reviews from real people who love our products."
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#1a1a1a"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 64
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 64
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "range",
          "id": "rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "label": "Star rating",
          "default": 5
        },
        {
          "type": "textarea",
          "id": "quote",
          "label": "Review text",
          "default": "Absolutely love the quality. Will definitely order again!"
        },
        {
          "type": "text",
          "id": "author_name",
          "label": "Author name",
          "default": "Sarah M."
        },
        {
          "type": "text",
          "id": "author_title",
          "label": "Author subtitle",
          "default": "Verified Buyer"
        },
        {
          "type": "image_picker",
          "id": "author_image",
          "label": "Author photo"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Premium Reviews",
      "blocks": [
        { "type": "review" },
        { "type": "review" },
        { "type": "review" }
      ]
    }
  ]
}
{% endschema %}
