<section
  class="premium-section premium-reviews"
  id="PremiumReviews-{{ section.id }}"
  style="
    background-color: {{ section.settings.background_color }};
    color: {{ section.settings.text_color }};
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  "
  data-reviews-slider
>
  <div class="page-width">
    <header class="premium-reviews__header">
      {% if section.settings.eyebrow != blank %}
        <span class="premium-section__eyebrow">{{ section.settings.eyebrow }}</span>
      {% endif %}
      {% if section.settings.heading != blank %}
        <h2 class="premium-section__heading">{{ section.settings.heading }}</h2>
      {% endif %}
      {% if section.settings.subheading != blank %}
        <p class="premium-section__subheading">{{ section.settings.subheading }}</p>
      {% endif %}
    </header>

    <div class="premium-reviews__slider" data-slider>
      <div class="premium-reviews__track" data-track>
        {% for block in section.blocks %}
          {% liquid
            assign author = block.settings.author_name | default: 'Customer'
            assign initial = author | strip | slice: 0, 1 | upcase
          %}
          <article class="premium-reviews__card" role="group" aria-roledescription="slide" {{ block.shopify_attributes }}>
            <div class="premium-reviews__stars" aria-label="{{ block.settings.rating }} out of 5 stars">
              {% for i in (1..5) %}
                <span class="premium-reviews__star{% if i > block.settings.rating %} premium-reviews__star--empty{% endif %}" aria-hidden="true">★</span>
              {% endfor %}
            </div>

            {% if block.settings.quote != blank %}
              <blockquote class="premium-reviews__quote">
                <p>{{ block.settings.quote }}</p>
              </blockquote>
            {% endif %}

            <footer class="premium-reviews__author">
              {% if block.settings.author_image != blank %}
                {{
                  block.settings.author_image
                  | image_url: width: 96
                  | image_tag:
                    loading: 'lazy',
                    width: 48,
                    height: 48,
                    class: 'premium-reviews__avatar',
                    alt: author | escape
                }}
              {% else %}
                <span class="premium-reviews__avatar premium-reviews__avatar--initial" aria-hidden="true">{{ initial }}</span>
              {% endif %}
              <div>
                <cite class="premium-reviews__name">{{ author }}</cite>
                {% if block.settings.author_title != blank %}
                  <span class="premium-reviews__title">{{ block.settings.author_title }}</span>
                {% endif %}
              </div>
            </footer>
          </article>
        {% else %}
          {% assign defaults = 'Sarah M.|Verified Buyer|I noticed a softer glow after a few uses. Lightweight and absorbs beautifully.|Priya K.|Verified Buyer|Beautiful packaging and the products feel luxurious. Highly recommend!|Emma L.|Verified Buyer|Fast shipping and amazing quality. This is now my everyday essential.|Ayesha R.|Verified Buyer|Gentle on my sensitive skin and still gives a healthy, natural finish.' | split: '|' %}
          {% comment %} fallback handled below via loop of 4 hardcoded if no blocks - schema presets cover this {% endcomment %}
        {% endfor %}
      </div>
    </div>

    <div class="premium-reviews__controls">
      <button type="button" class="premium-reviews__arrow" data-prev aria-label="Previous reviews">
        <span aria-hidden="true">‹</span>
      </button>
      <div class="premium-reviews__dots" data-dots role="tablist" aria-label="Review slides"></div>
      <button type="button" class="premium-reviews__arrow" data-next aria-label="Next reviews">
        <span aria-hidden="true">›</span>
      </button>
    </div>
  </div>
</section>

<script>
  (() => {
    const root = document.getElementById('PremiumReviews-{{ section.id }}');
    if (!root) return;

    const track = root.querySelector('[data-track]');
    const cards = [...track.querySelectorAll('.premium-reviews__card')];
    const dotsWrap = root.querySelector('[data-dots]');
    const prevBtn = root.querySelector('[data-prev]');
    const nextBtn = root.querySelector('[data-next]');
    if (!cards.length) return;

    let index = 0;
    let perView = 1;

    const getPerView = () => (window.matchMedia('(min-width: 990px)').matches ? 4 : window.matchMedia('(min-width: 750px)').matches ? 2 : 1);

    const pageCount = () => Math.max(1, Math.ceil(cards.length / perView));

    const renderDots = () => {
      dotsWrap.innerHTML = '';
      const pages = pageCount();
      for (let i = 0; i < pages; i++) {
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'premium-reviews__dot' + (i === index ? ' is-active' : '');
        btn.setAttribute('aria-label', 'Go to slide ' + (i + 1));
        btn.setAttribute('aria-current', i === index ? 'true' : 'false');
        btn.addEventListener('click', () => {
          index = i;
          update();
        });
        dotsWrap.appendChild(btn);
      }
    };

    const update = () => {
      perView = getPerView();
      const pages = pageCount();
      if (index > pages - 1) index = pages - 1;
      const offset = index * perView;
      const cardWidth = cards[0].getBoundingClientRect().width;
      const styles = window.getComputedStyle(track);
      const gap = parseFloat(styles.columnGap || styles.gap || '0') || 0;
      const shift = offset * (cardWidth + gap);
      track.style.transform = `translateX(-${shift}px)`;
      [...dotsWrap.children].forEach((dot, i) => {
        dot.classList.toggle('is-active', i === index);
        dot.setAttribute('aria-current', i === index ? 'true' : 'false');
      });
      prevBtn.disabled = index <= 0;
      nextBtn.disabled = index >= pages - 1;
    };

    const refresh = () => {
      perView = getPerView();
      cards.forEach((card) => {
        card.style.flex = `0 0 calc((100% - ${(perView - 1) * 1.25}rem) / ${perView})`;
      });
      renderDots();
      update();
    };

    prevBtn.addEventListener('click', () => {
      index = Math.max(0, index - 1);
      update();
    });
    nextBtn.addEventListener('click', () => {
      index = Math.min(pageCount() - 1, index + 1);
      update();
    });

    let resizeTimer;
    window.addEventListener('resize', () => {
      clearTimeout(resizeTimer);
      resizeTimer = setTimeout(refresh, 120);
    });

    refresh();
  })();
</script>

{% stylesheet %}
  .premium-reviews__header {
    text-align: center;
    margin-bottom: 2.5rem;
  }

  .premium-reviews__header .premium-section__subheading {
    margin-inline: auto;
  }

  .premium-reviews__slider {
    overflow: hidden;
  }

  .premium-reviews__track {
    display: flex;
    gap: 1.25rem;
    transition: transform 0.55s var(--beauty-ease, cubic-bezier(0.22, 1, 0.36, 1));
    will-change: transform;
  }

  .premium-reviews__card {
    flex: 0 0 100%;
    min-width: 0;
    padding: 1.75rem 1.5rem;
    border: 1px solid var(--beauty-line, #e5dfd8);
    background: color-mix(in srgb, #fff 72%, var(--beauty-bg-soft, #f7f5f3));
    border-radius: 2px;
    display: flex;
    flex-direction: column;
    min-height: 100%;
  }

  .premium-reviews__stars {
    margin-bottom: 1rem;
    font-size: 0.8125rem;
    letter-spacing: 0.12em;
    color: var(--beauty-accent, #8f6a5b);
  }

  .premium-reviews__star--empty {
    opacity: 0.25;
  }

  .premium-reviews__quote {
    margin: 0 0 1.5rem;
    flex: 1;
  }

  .premium-reviews__quote p {
    margin: 0;
    font-size: 0.975rem;
    line-height: 1.65;
  }

  .premium-reviews__author {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .premium-reviews__avatar {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
  }

  .premium-reviews__avatar--initial {
    display: inline-grid;
    place-items: center;
    background: linear-gradient(145deg, #f3ebe6 0%, #c9a99a 100%);
    color: #1c1917;
    font-size: 1rem;
    font-weight: 600;
    letter-spacing: 0.04em;
  }

  .premium-reviews__name {
    display: block;
    font-style: normal;
    font-weight: 600;
    font-size: 0.875rem;
  }

  .premium-reviews__title {
    display: block;
    font-size: 0.75rem;
    opacity: 0.65;
  }

  .premium-reviews__controls {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin-top: 1.75rem;
  }

  .premium-reviews__arrow {
    width: 2.5rem;
    height: 2.5rem;
    border: 1px solid var(--beauty-line, #e5dfd8);
    background: #fff;
    border-radius: 50%;
    cursor: pointer;
    font-size: 1.35rem;
    line-height: 1;
    color: var(--beauty-ink, #1c1917);
    transition: background-color 0.25s ease, border-color 0.25s ease, opacity 0.25s ease;
  }

  .premium-reviews__arrow:hover:not(:disabled) {
    border-color: var(--beauty-accent, #8f6a5b);
    background: var(--beauty-bg-blush, #f3ebe6);
  }

  .premium-reviews__arrow:disabled {
    opacity: 0.35;
    cursor: default;
  }

  .premium-reviews__dots {
    display: flex;
    align-items: center;
    gap: 0.65rem;
  }

  /* Unique antique pagination line/dots */
  .premium-reviews__dot {
    appearance: none;
    border: 0;
    padding: 0;
    width: 1.35rem;
    height: 0.28rem;
    border-radius: 999px;
    background:
      linear-gradient(90deg, transparent 0%, rgba(143, 106, 91, 0.35) 18%, rgba(143, 106, 91, 0.35) 82%, transparent 100%),
      radial-gradient(circle at center, #8f6a5b 0 1.5px, transparent 1.7px);
    background-color: transparent;
    background-repeat: no-repeat;
    background-position: center;
    background-size: 100% 2px, 6px 6px;
    cursor: pointer;
    position: relative;
    opacity: 0.45;
    transition: width 0.35s var(--beauty-ease, ease), opacity 0.25s ease, background-size 0.35s ease;
  }

  .premium-reviews__dot::before,
  .premium-reviews__dot::after {
    content: '';
    position: absolute;
    top: 50%;
    width: 5px;
    height: 5px;
    border: 1px solid rgba(143, 106, 91, 0.55);
    border-radius: 1px;
    transform: translateY(-50%) rotate(45deg);
    opacity: 0;
    transition: opacity 0.25s ease;
  }

  .premium-reviews__dot::before {
    left: -0.15rem;
  }

  .premium-reviews__dot::after {
    right: -0.15rem;
  }

  .premium-reviews__dot.is-active {
    width: 2.35rem;
    opacity: 1;
    background:
      linear-gradient(90deg, #c9a99a 0%, #8f6a5b 50%, #c9a99a 100%),
      radial-gradient(circle at center, #1c1917 0 2px, transparent 2.2px);
    background-repeat: no-repeat;
    background-position: center;
    background-size: 100% 2px, 7px 7px;
  }

  .premium-reviews__dot.is-active::before,
  .premium-reviews__dot.is-active::after {
    opacity: 1;
  }

  @media (prefers-reduced-motion: reduce) {
    .premium-reviews__track {
      transition: none;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "Premium Reviews",
  "tag": "section",
  "class": "premium-reviews-section",
  "max_blocks": 12,
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Loved by Customers"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Real Reviews"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Honest words from people who made it part of their everyday ritual."
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#1c1917"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 72
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 72
    }
  ],
  "blocks": [
    {
      "type": "review",
      "name": "Review",
      "settings": [
        {
          "type": "range",
          "id": "rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "label": "Star rating",
          "default": 5
        },
        {
          "type": "textarea",
          "id": "quote",
          "label": "Review text",
          "default": "Absolutely love the quality. Will definitely order again!"
        },
        {
          "type": "text",
          "id": "author_name",
          "label": "Customer name",
          "default": "Sarah M."
        },
        {
          "type": "text",
          "id": "author_title",
          "label": "Subtitle",
          "default": "Verified Buyer"
        },
        {
          "type": "image_picker",
          "id": "author_image",
          "label": "Customer photo",
          "info": "If empty, the first letter of the name is shown"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Premium Reviews",
      "blocks": [
        { "type": "review" },
        { "type": "review" },
        { "type": "review" },
        { "type": "review" }
      ]
    }
  ]
}
{% endschema %}
